<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fare Requests - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .fare-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      margin-bottom: 16px;
    }
    .fare-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      background: var(--blue-50);
      border-bottom: 1px solid var(--blue-100, #dbeafe);
      gap: 12px;
      flex-wrap: wrap;
    }
    .fare-route {
      font-size: 1rem;
      font-weight: 700;
      color: var(--blue-700, #1d4ed8);
    }
    .fare-meta {
      font-size: 0.78rem;
      color: var(--blue-500, #3b82f6);
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 3px;
    }
    .fare-meta span { display: flex; align-items: center; gap: 4px; }

    .fare-card-body {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px;
      padding: 18px 20px;
      align-items: start;
    }
    @media (max-width: 640px) { .fare-card-body { grid-template-columns: 1fr; } }

    .passenger-info { font-size: 0.875rem; }
    .passenger-info strong { display: block; color: var(--gray-900); font-size: 0.95rem; }
    .passenger-info span { color: var(--gray-500); }

    .proposed-fare {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: #fefce8;
      border: 1px solid #fde68a;
      border-radius: var(--radius);
      font-size: 0.875rem;
    }
    .proposed-fare strong { font-size: 1.1rem; color: #92400e; }
    .proposed-fare span { color: #78350f; }

    .action-forms {
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-width: 240px;
    }
    .action-row { display: flex; gap: 8px; }
    .counter-row {
      display: flex;
      gap: 6px;
      align-items: center;
      padding: 10px 12px;
      background: var(--gray-50);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
    }
    .counter-row input {
      flex: 1;
      padding: 6px 10px;
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      font-size: 0.85rem;
      outline: none;
      min-width: 0;
      transition: border-color 0.15s;
    }
    .counter-row input:focus { border-color: var(--blue-400); }
    .counter-label {
      font-size: 0.75rem; font-weight: 600;
      color: var(--gray-600); margin-bottom: 4px;
      display: block;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <div class="page-header">
      <div style="display:flex;align-items:center;gap:10px">
        <h1>Fare Requests</h1>
        <% if (fareRequests.length > 0) { %>
          <span style="background:var(--blue-600);color:#fff;font-size:0.7rem;font-weight:700;padding:3px 9px;border-radius:999px"><%= fareRequests.length %> pending</span>
        <% } %>
      </div>
      <p>Review and respond to passenger fare proposals for your rides.</p>
    </div>

    <!-- ── Flash messages ─────────────────────────────────────────── -->
    <% if (success === 'approved') { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Fare approved. Booking confirmed and seat reserved.
      </div>
    <% } else if (success === 'rejected') { %>
      <div class="alert alert-warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        Fare rejected. Booking cancelled.
      </div>
    <% } else if (success === 'countered') { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Counter offer sent. Waiting for passenger to respond.
      </div>
    <% } %>
    <% if (error === 'not_found') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Fare request not found or already processed.
      </div>
    <% } else if (error === 'invalid_fare') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Please enter a valid counter fare amount.
      </div>
    <% } else if (error === 'ride_full') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        No seats available to approve this booking.
      </div>
    <% } %>

    <!-- ── Fare request cards ──────────────────────────────────────── -->
    <% if (fareRequests.length === 0) { %>
      <div class="card" style="text-align:center">
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <p>No pending fare requests at the moment.</p>
          <a href="/driver/dashboard" class="btn btn-secondary btn-sm" style="margin-top:8px">← Back to Dashboard</a>
        </div>
      </div>
    <% } else { %>
      <div style="margin-bottom:16px;display:flex;justify-content:flex-end">
        <a href="/driver/dashboard" class="btn btn-secondary btn-sm">← Back to Dashboard</a>
      </div>

      <% fareRequests.forEach(function(fr) { %>
      <div class="fare-card">
        <div class="fare-card-header">
          <div>
            <div class="fare-route"><%= fr.Origin %> → <%= fr.Destination %></div>
            <div class="fare-meta">
              <span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <%= new Date(fr.DepartureTime).toLocaleString('en-PK', {dateStyle:'medium', timeStyle:'short'}) %>
              </span>
              <span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/></svg>
                <%= fr.AvailableSeats %> seat<%= fr.AvailableSeats !== 1 ? 's' : '' %> available
              </span>
              <span style="font-size:0.72rem;color:var(--blue-400)">
                Booking #<%= fr.BookingID %>
              </span>
            </div>
          </div>
          <div class="proposed-fare">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="3"/></svg>
            <div>
              <span>Proposed fare</span>
              <strong>Rs. <%= Number(fr.ProposedFare).toLocaleString('en-PK') %></strong>
            </div>
          </div>
        </div>

        <div class="fare-card-body">
          <div>
            <div class="passenger-info">
              <strong><%= fr.PassengerName %></strong>
              <span><%= fr.PassengerPhone %></span>
            </div>
            <div style="margin-top:10px;font-size:0.78rem;color:var(--gray-500)">
              Request received: <%= new Date(fr.BookingTime).toLocaleString('en-PK', {dateStyle:'medium', timeStyle:'short'}) %>
            </div>
          </div>

          <div class="action-forms">
            <!-- Approve -->
            <div class="action-row">
              <form action="/driver/fare-response/<%= fr.BookingID %>" method="POST" style="margin:0;flex:1">
                <input type="hidden" name="action" value="approve">
                <button type="submit" class="btn btn-success btn-sm" style="width:100%">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  Approve Rs. <%= Number(fr.ProposedFare).toLocaleString('en-PK') %>
                </button>
              </form>
              <form action="/driver/fare-response/<%= fr.BookingID %>" method="POST" style="margin:0">
                <input type="hidden" name="action" value="reject">
                <button type="submit" class="btn btn-danger btn-sm"
                        onclick="return confirm('Reject this fare request? The booking will be cancelled.')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  Reject
                </button>
              </form>
            </div>

            <!-- Counter offer -->
            <form action="/driver/fare-response/<%= fr.BookingID %>" method="POST" style="margin:0">
              <input type="hidden" name="action" value="counter">
              <span class="counter-label">Or send a counter offer:</span>
              <div class="counter-row">
                <span style="font-size:0.8rem;font-weight:600;color:var(--gray-500);flex-shrink:0">Rs.</span>
                <input type="number" name="counterFare" min="1" step="1" placeholder="Enter amount" required>
                <button type="submit" class="btn btn-secondary btn-sm" style="white-space:nowrap;flex-shrink:0">
                  Counter
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <% }); %>
    <% } %>

  </div>
</body>
</html>
