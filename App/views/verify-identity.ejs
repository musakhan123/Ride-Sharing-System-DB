<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Identity Verification - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper" style="max-width:580px">

    <div class="page-header">
      <h1>Identity Verification</h1>
      <p>Submit a government-issued document to verify your identity.</p>
    </div>

    <% if (success) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <%= success %>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <%= error %>
      </div>
    <% } %>

    <% if (existing && existing.Status === 'verified') { %>

      <!-- ── Verified ──────────────────────────────────────────────── -->
      <div class="alert" style="background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;border-radius:var(--radius);padding:14px 18px;display:flex;align-items:center;gap:10px;margin-bottom:20px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span style="font-weight:600">Identity verified successfully.</span>
      </div>

      <div class="card">
        <div class="card-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Document Type</div>
              <div style="margin-top:5px;font-weight:500;color:var(--gray-900);text-transform:capitalize">
                <%= existing.DocumentType.replace('_', ' ') %>
              </div>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Document Number</div>
              <div style="margin-top:5px">
                <code style="background:var(--gray-100);padding:2px 8px;border-radius:4px;font-size:0.85rem"><%= existing.DocumentNumber %></code>
              </div>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Verified On</div>
              <div style="margin-top:5px;font-size:0.875rem;color:var(--gray-700)">
                <%= new Date(existing.SubmittedAt).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %>
              </div>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Status</div>
              <div style="margin-top:7px"><span class="badge badge-active">Verified</span></div>
            </div>
          </div>
        </div>
      </div>

    <% } else if (existing && existing.Status === 'pending') { %>

      <!-- ── Pending ────────────────────────────────────────────────── -->
      <div class="alert" style="background:#fef3c7;color:#78350f;border:1px solid #fcd34d;border-radius:var(--radius);padding:14px 18px;display:flex;align-items:center;gap:10px;margin-bottom:20px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span style="font-weight:600">Your verification is under review.</span>
        <span style="font-weight:400;margin-left:2px">We'll notify you once it's processed.</span>
      </div>

      <div class="card">
        <div class="card-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Document Type</div>
              <div style="margin-top:5px;font-weight:500;color:var(--gray-900);text-transform:capitalize">
                <%= existing.DocumentType.replace('_', ' ') %>
              </div>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Document Number</div>
              <div style="margin-top:5px">
                <code style="background:var(--gray-100);padding:2px 8px;border-radius:4px;font-size:0.85rem"><%= existing.DocumentNumber %></code>
              </div>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Submitted On</div>
              <div style="margin-top:5px;font-size:0.875rem;color:var(--gray-700)">
                <%= new Date(existing.SubmittedAt).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %>
              </div>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Status</div>
              <div style="margin-top:7px"><span class="badge badge-pending">Pending review</span></div>
            </div>
            <% if (existing.DocumentFile) { %>
              <div style="grid-column:1/-1">
                <div style="font-size:0.72rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.6px">Uploaded Document</div>
                <div style="margin-top:8px">
                  <% const pendingExt = existing.DocumentFile.split('.').pop().toLowerCase(); %>
                  <% if (['jpg','jpeg','png'].includes(pendingExt)) { %>
                    <a href="/uploads/<%= existing.DocumentFile %>" target="_blank"
                       style="display:inline-block;border-radius:var(--radius);overflow:hidden;border:2px solid var(--blue-100)" title="Click to view">
                      <img src="/uploads/<%= existing.DocumentFile %>"
                           style="display:block;max-width:220px;max-height:140px;object-fit:cover" alt="Uploaded document">
                    </a>
                  <% } else { %>
                    <a href="/uploads/<%= existing.DocumentFile %>" target="_blank"
                       style="display:inline-flex;align-items:center;gap:7px;padding:8px 14px;border:1px solid var(--gray-200);border-radius:var(--radius);color:var(--blue-600);font-size:0.875rem;font-weight:500;text-decoration:none;background:var(--white)">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                      </svg>
                      View Document (PDF)
                    </a>
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      </div>

    <% } else { %>

      <!-- ── Rejected banner (shown only when status is rejected) ───── -->
      <% if (existing && existing.Status === 'rejected') { %>
        <div class="alert alert-error" style="margin-bottom:24px">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
          <div>
            <div style="font-weight:600">Your verification was rejected. Please resubmit with correct documents.</div>
            <% if (existing.RejectionReason) { %>
              <div style="margin-top:4px;font-size:0.85rem;opacity:0.85">
                Reason: <%= existing.RejectionReason %>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- ── Submission / Resubmission form ────────────────────────── -->
      <div class="card">
        <div class="card-header">
          <h2><%= existing ? 'Resubmit Documents' : 'Submit Documents' %></h2>
          <div class="card-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
        </div>
        <div class="card-body">
          <form action="/auth/verify-identity" method="POST" enctype="multipart/form-data">
            <div style="display:flex;flex-direction:column;gap:18px">

              <div class="form-group">
                <label for="documentType">Document Type</label>
                <select id="documentType" name="documentType" required>
                  <option value="">Select a document type</option>
                  <option value="CNIC"<%= existing && existing.DocumentType === 'CNIC' ? ' selected' : '' %>>CNIC (National Identity Card)</option>
                  <option value="student_card"<%= existing && existing.DocumentType === 'student_card' ? ' selected' : '' %>>Student Card</option>
                  <option value="passport"<%= existing && existing.DocumentType === 'passport' ? ' selected' : '' %>>Passport</option>
                </select>
              </div>

              <div class="form-group">
                <label for="documentNumber">Document Number</label>
                <input type="text" id="documentNumber" name="documentNumber"
                       placeholder="e.g. 35202-1234567-8"
                       value="<%= existing ? existing.DocumentNumber : '' %>" required>
              </div>

              <div class="form-group">
                <label>
                  Document File
                  <span style="font-weight:400;color:var(--gray-500)"> — JPG, PNG, or PDF, max 5 MB</span>
                </label>
                <label class="file-upload-zone" id="fileZone" for="documentFile">
                  <div class="fuz-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <polyline points="16 16 12 12 8 16"/>
                      <line x1="12" y1="12" x2="12" y2="21"/>
                      <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
                    </svg>
                  </div>
                  <div class="fuz-label" id="fuz-label">
                    <strong>Click to upload</strong>&nbsp;or drag a file here
                  </div>
                  <div class="fuz-hint" id="fuz-hint">JPG, PNG or PDF up to 5 MB</div>
                  <input type="file" id="documentFile" name="documentFile"
                         accept=".jpg,.jpeg,.png,.pdf" required>
                </label>
              </div>

              <button type="submit" class="btn btn-primary" style="margin-top:2px">
                <%= existing ? 'Resubmit for Verification' : 'Submit for Verification' %>
              </button>

            </div>
          </form>
        </div>
      </div>

    <% } %>

  </div><!-- /page-wrapper -->

  <script>
    (function () {
      var input = document.getElementById('documentFile');
      if (!input) return;
      var zone  = document.getElementById('fileZone');
      var label = document.getElementById('fuz-label');
      var hint  = document.getElementById('fuz-hint');

      input.addEventListener('change', function () {
        if (!this.files.length) return;
        var f = this.files[0];
        var mb = (f.size / 1024 / 1024).toFixed(2);
        label.innerHTML = '<strong>' + f.name + '</strong>';
        hint.textContent = mb + ' MB — click to change';
        zone.classList.add('has-file');
      });
    })();
  </script>

</body>
</html>
