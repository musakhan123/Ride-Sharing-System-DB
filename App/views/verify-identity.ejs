<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Identity Verification - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper" style="max-width:560px">

    <div class="page-header">
      <h1>Identity Verification</h1>
      <p>Submit a government-issued document to verify your identity.</p>
    </div>

    <% if (success) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <%= success %>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
    <% } %>

    <% if (existing) { %>
      <!-- Status card -->
      <div class="card">
        <div class="card-body">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px">
            <% if (existing.Status === 'verified') { %>
              <div style="width:44px;height:44px;flex-shrink:0;border-radius:50%;background:#d1fae5;display:flex;align-items:center;justify-content:center">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#065f46" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <div style="font-weight:700;font-size:1rem;color:var(--gray-900)">Identity Verified</div>
                <div style="font-size:0.85rem;color:var(--gray-600);margin-top:2px">Your identity has been successfully verified.</div>
              </div>
            <% } else if (existing.Status === 'pending') { %>
              <div style="width:44px;height:44px;flex-shrink:0;border-radius:50%;background:#fef3c7;display:flex;align-items:center;justify-content:center">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <div style="font-weight:700;font-size:1rem;color:var(--gray-900)">Verification Pending</div>
                <div style="font-size:0.85rem;color:var(--gray-600);margin-top:2px">Your documents are under review. We'll notify you once processed.</div>
              </div>
            <% } else { %>
              <div style="width:44px;height:44px;flex-shrink:0;border-radius:50%;background:#fee2e2;display:flex;align-items:center;justify-content:center">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#991b1b" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              </div>
              <div>
                <div style="font-weight:700;font-size:1rem;color:var(--gray-900)">Verification Rejected</div>
                <div style="font-size:0.85rem;color:var(--gray-600);margin-top:2px">Your documents were not accepted. Please contact support.</div>
              </div>
            <% } %>
          </div>

          <hr class="divider">

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px">
            <div>
              <div style="font-size:0.75rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.5px">Document Type</div>
              <div style="margin-top:4px;font-weight:500;color:var(--gray-900);text-transform:capitalize"><%= existing.DocumentType.replace('_', ' ') %></div>
            </div>
            <div>
              <div style="font-size:0.75rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.5px">Document Number</div>
              <div style="margin-top:4px;font-weight:500;color:var(--gray-900)">
                <code style="background:var(--gray-100);padding:2px 8px;border-radius:4px;font-size:0.85rem"><%= existing.DocumentNumber %></code>
              </div>
            </div>
            <div>
              <div style="font-size:0.75rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.5px">Submitted On</div>
              <div style="margin-top:4px;font-size:0.875rem;color:var(--gray-700)">
                <%= new Date(existing.SubmittedAt).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %>
              </div>
            </div>
            <div>
              <div style="font-size:0.75rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.5px">Status</div>
              <div style="margin-top:6px">
                <% if (existing.Status === 'verified') { %>
                  <span class="badge badge-active">Verified</span>
                <% } else if (existing.Status === 'pending') { %>
                  <span class="badge badge-pending">Pending</span>
                <% } else { %>
                  <span class="badge badge-cancelled">Rejected</span>
                <% } %>
              </div>
            </div>
            <% if (existing.DocumentFile) { %>
              <div style="grid-column:1/-1">
                <div style="font-size:0.75rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:0.5px">Uploaded Document</div>
                <div style="margin-top:6px">
                  <a href="/uploads/<%= existing.DocumentFile %>" target="_blank"
                     style="display:inline-flex;align-items:center;gap:6px;color:var(--blue-600);font-size:0.875rem;font-weight:500;text-decoration:none">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    View Document
                  </a>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      </div>

    <% } else { %>
      <!-- Submission form -->
      <div class="card">
        <div class="card-header">
          <h2>Submit Documents</h2>
          <div class="card-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
        </div>
        <div class="card-body">
          <form action="/auth/verify-identity" method="POST" enctype="multipart/form-data">
            <div style="display:flex;flex-direction:column;gap:16px">
              <div class="form-group">
                <label for="documentType">Document Type</label>
                <select id="documentType" name="documentType" required>
                  <option value="">Select a document type</option>
                  <option value="CNIC">CNIC (National Identity Card)</option>
                  <option value="student_card">Student Card</option>
                  <option value="passport">Passport</option>
                </select>
              </div>
              <div class="form-group">
                <label for="documentNumber">Document Number</label>
                <input type="text" id="documentNumber" name="documentNumber"
                       placeholder="e.g. 35202-1234567-8" required>
              </div>
              <div class="form-group">
                <label for="documentFile">Document File <span style="font-weight:400;color:var(--gray-600)">(JPG, PNG, or PDF — max 5 MB)</span></label>
                <input type="file" id="documentFile" name="documentFile"
                       accept=".jpg,.jpeg,.png,.pdf" required
                       style="padding:8px;border:1px solid var(--gray-300);border-radius:var(--radius);font-size:0.875rem;background:var(--white)">
              </div>
              <button type="submit" class="btn btn-primary">Submit for Verification</button>
            </div>
          </form>
        </div>
      </div>
    <% } %>

  </div>

</body>
</html>
