<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ride History - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .filter-bar { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:0; }
    .filter-btn {
      padding:5px 16px; border-radius:999px; border:1.5px solid var(--gray-200);
      background:var(--white); color:var(--gray-600); font-size:0.82rem;
      font-weight:600; cursor:pointer; transition:all 0.15s; line-height:1.6;
    }
    .filter-btn:hover { border-color:var(--blue-500); color:var(--blue-600); }
    .filter-btn.active { background:var(--blue-600); color:var(--white); border-color:var(--blue-600); }

    .route-cell strong { display:block; font-size:0.875rem; color:var(--gray-900); }
    .route-cell span   { font-size:0.75rem; color:var(--gray-500); }

    .booking-counts { display:flex; flex-direction:column; gap:2px; font-size:0.78rem; }
    .booking-counts .total { font-weight:700; color:var(--gray-800); font-size:0.9rem; }
    .booking-counts .detail { color:var(--gray-500); }

    .empty-filtered {
      display:none; text-align:center; padding:40px 20px;
      color:var(--gray-500); font-size:0.9rem;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <!-- ── Page header ───────────────────────────────────────────── -->
    <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px">
      <div>
        <h1>Ride History</h1>
        <p>All rides you have posted — completed, active, and cancelled.</p>
      </div>
      <a href="/driver/dashboard" class="btn btn-secondary btn-sm">← Dashboard</a>
    </div>

    <!-- ── Flash messages ─────────────────────────────────────────── -->
    <% if (typeof completed !== 'undefined' && completed) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Ride marked as completed. All confirmed bookings have been updated.
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error === 'not_found') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Ride not found or already completed.
      </div>
    <% } %>

    <% if (rides.length === 0) { %>
      <div class="card">
        <div class="empty-state" style="padding:64px 20px">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="color:var(--gray-200)">
            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <p style="color:var(--gray-500);margin-top:10px">No rides posted yet.</p>
          <a href="/driver/dashboard" class="btn btn-primary btn-sm" style="margin-top:16px;width:auto;padding:8px 20px">Post Your First Ride →</a>
        </div>
      </div>
    <% } else { %>

      <!-- ── Stats row ────────────────────────────────────────────── -->
      <div class="stats-grid" style="margin-bottom:28px">
        <div class="stat-card">
          <div class="stat-label">Total Rides</div>
          <div class="stat-value"><%= rides.length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active</div>
          <div class="stat-value" style="color:var(--blue-600)"><%= rides.filter(r => r.Status === 'active').length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Completed</div>
          <div class="stat-value green"><%= rides.filter(r => r.Status === 'completed').length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Bookings</div>
          <div class="stat-value"><%= rides.reduce((s,r) => s + Number(r.TotalBookings || 0), 0) %></div>
        </div>
      </div>

      <!-- ── Table card ────────────────────────────────────────────── -->
      <div class="card" style="padding:0;overflow:hidden">
        <div class="card-header">
          <h2>All Rides</h2>
          <div class="filter-bar">
            <button class="filter-btn active" onclick="filterStatus('all', this)">All</button>
            <button class="filter-btn" onclick="filterStatus('active', this)">Active</button>
            <button class="filter-btn" onclick="filterStatus('completed', this)">Completed</button>
            <button class="filter-btn" onclick="filterStatus('cancelled', this)">Cancelled</button>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Route</th>
                <th>Departure</th>
                <th>Vehicle</th>
                <th>Seats Filled</th>
                <th>Bookings</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="ridesTableBody">
              <% rides.forEach(r => { %>
                <tr data-status="<%= r.Status %>"
                    style="<%= r.Status === 'cancelled' ? 'opacity:0.55' : '' %>">

                  <td class="route-cell">
                    <strong><%= r.Origin %> &rarr; <%= r.Destination %></strong>
                  </td>

                  <td style="white-space:nowrap;font-size:0.85rem;color:var(--gray-700)">
                    <%= new Date(r.DepartureTime).toLocaleString('en-PK', {dateStyle:'medium', timeStyle:'short'}) %>
                  </td>

                  <td>
                    <div style="font-weight:600;font-size:0.85rem"><%= r.Make %> <%= r.Model %></div>
                    <code style="background:var(--gray-100);padding:1px 6px;border-radius:4px;font-size:0.72rem"><%= r.PlateNumber %></code>
                  </td>

                  <td>
                    <span style="font-weight:700;color:var(--blue-700);font-size:1rem"><%= r.TotalSeats - r.AvailableSeats %></span>
                    <span style="color:var(--gray-400)"> / <%= r.TotalSeats %></span>
                    <div style="height:4px;background:var(--gray-100);border-radius:999px;margin-top:5px;width:60px">
                      <% var pct = r.TotalSeats > 0 ? Math.round((r.TotalSeats - r.AvailableSeats) / r.TotalSeats * 100) : 0; %>
                      <div style="height:4px;background:var(--blue-500);border-radius:999px;width:<%= pct %>%"></div>
                    </div>
                  </td>

                  <td>
                    <div class="booking-counts">
                      <span class="total"><%= r.TotalBookings || 0 %></span>
                      <% if (Number(r.CompletedBookings) > 0) { %>
                        <span class="detail" style="color:#065f46"><%= r.CompletedBookings %> completed</span>
                      <% } %>
                      <% if (Number(r.ConfirmedBookings) > 0) { %>
                        <span class="detail" style="color:var(--blue-600)"><%= r.ConfirmedBookings %> confirmed</span>
                      <% } %>
                      <% if (Number(r.CancelledBookings) > 0) { %>
                        <span class="detail"><%= r.CancelledBookings %> cancelled</span>
                      <% } %>
                    </div>
                  </td>

                  <td>
                    <span class="badge badge-<%= r.Status %>"><%= r.Status %></span>
                  </td>

                  <td>
                    <% if (r.Status === 'active') { %>
                      <form action="/driver/complete-ride/<%= r.RideID %>" method="POST">
                        <button type="submit">Mark as Completed</button>
                      </form>
                    <% } else { %>
                      <span style="color:var(--gray-300);font-size:0.8rem">—</span>
                    <% } %>
                  </td>

                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="empty-filtered" id="emptyFiltered">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--gray-200);margin-bottom:8px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <div>No rides match this filter.</div>
        </div>
      </div>

    <% } %>
  </div>

  <script>
    function filterStatus(status, btn) {
      document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var rows    = document.querySelectorAll('#ridesTableBody tr[data-status]');
      var visible = 0;
      rows.forEach(function(row) {
        var show = status === 'all' || row.dataset.status === status;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.getElementById('emptyFiltered').style.display = visible === 0 ? 'block' : 'none';
    }
  </script>

</body>
</html>
