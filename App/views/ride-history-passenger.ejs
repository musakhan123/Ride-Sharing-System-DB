<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ride History - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .filter-bar { display:flex; gap:8px; flex-wrap:wrap; }
    .filter-btn {
      padding:5px 16px; border-radius:999px; border:1.5px solid var(--gray-200);
      background:var(--white); color:var(--gray-600); font-size:0.82rem;
      font-weight:600; cursor:pointer; transition:all 0.15s; line-height:1.6;
    }
    .filter-btn:hover { border-color:var(--blue-500); color:var(--blue-600); }
    .filter-btn.active { background:var(--blue-600); color:var(--white); border-color:var(--blue-600); }

    .route-cell strong { display:block; font-size:0.875rem; color:var(--gray-900); }
    .route-cell span   { font-size:0.75rem; color:var(--gray-500); }

    .empty-filtered {
      display:none; text-align:center; padding:40px 20px;
      color:var(--gray-500); font-size:0.9rem;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <!-- ── Page header ────────────────────────────────────────────── -->
    <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px">
      <div>
        <h1>Ride History</h1>
        <p>Your completed and cancelled trips, <%= user.Name %>.</p>
      </div>
      <div style="display:flex;gap:8px">
        <a href="/passenger/my-bookings" class="btn btn-secondary btn-sm">Active Bookings</a>
        <a href="/passenger/dashboard" class="btn btn-secondary btn-sm">← Dashboard</a>
      </div>
    </div>

    <% if (bookings.length === 0) { %>
      <div class="card">
        <div class="empty-state" style="padding:64px 20px">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="color:var(--gray-200)">
            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <p style="color:var(--gray-500);margin-top:10px">No completed or cancelled trips yet.</p>
          <a href="/passenger/dashboard" class="btn btn-primary btn-sm" style="margin-top:16px;width:auto;padding:8px 20px">Find a Ride →</a>
        </div>
      </div>
    <% } else { %>

      <!-- ── Stats row ─────────────────────────────────────────────── -->
      <% var totalSpent = bookings.filter(b => b.PaymentStatus === 'completed').reduce((s,b) => s + Number(b.Amount || 0), 0); %>
      <div class="stats-grid" style="margin-bottom:28px">
        <div class="stat-card">
          <div class="stat-label">Total Trips</div>
          <div class="stat-value"><%= bookings.length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Completed</div>
          <div class="stat-value green"><%= bookings.filter(b => b.BookingStatus === 'completed').length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Cancelled</div>
          <div class="stat-value" style="color:var(--red)"><%= bookings.filter(b => b.BookingStatus === 'cancelled').length %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Spent</div>
          <div class="stat-value yellow">Rs. <%= totalSpent.toLocaleString('en-PK') %></div>
        </div>
      </div>

      <!-- ── Table card ─────────────────────────────────────────────── -->
      <div class="card" style="padding:0;overflow:hidden">
        <div class="card-header">
          <h2>Trip History</h2>
          <div class="filter-bar">
            <button class="filter-btn active" onclick="filterStatus('all', this)">All</button>
            <button class="filter-btn" onclick="filterStatus('completed', this)">Completed</button>
            <button class="filter-btn" onclick="filterStatus('cancelled', this)">Cancelled</button>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Route</th>
                <th>Departure</th>
                <th>Driver / Vehicle</th>
                <th>Fare Paid</th>
                <th>Payment</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="bookingsBody">
              <% bookings.forEach(function(b) { %>
                <tr data-status="<%= b.BookingStatus %>"
                    style="<%= b.BookingStatus === 'cancelled' ? 'opacity:0.55' : '' %>">

                  <td style="color:var(--gray-400);font-size:0.78rem">#<%= b.BookingID %></td>

                  <td class="route-cell">
                    <strong><%= b.Origin %> &rarr; <%= b.Destination %></strong>
                    <span><%= b.OriginCity %> &rarr; <%= b.DestinationCity %></span>
                  </td>

                  <td style="white-space:nowrap;font-size:0.85rem;color:var(--gray-700)">
                    <%= new Date(b.DepartureTime).toLocaleString('en-PK', {dateStyle:'medium', timeStyle:'short'}) %>
                  </td>

                  <td>
                    <div style="font-weight:600;font-size:0.85rem;color:var(--gray-900)"><%= b.DriverName %></div>
                    <div style="font-size:0.75rem;color:var(--gray-500)"><%= b.Make %> <%= b.Model %></div>
                    <code style="background:var(--gray-100);padding:1px 6px;border-radius:4px;font-size:0.72rem"><%= b.PlateNumber %></code>
                  </td>

                  <td>
                    <% var fare = Number(b.DriverFare || b.ProposedFare || 0); %>
                    <% if (fare > 0) { %>
                      <span style="font-weight:700;color:var(--gray-900)">Rs. <%= fare.toLocaleString('en-PK') %></span>
                    <% } else { %>
                      <span style="color:var(--gray-300)">—</span>
                    <% } %>
                  </td>

                  <td>
                    <% if (b.PaymentStatus === 'completed') { %>
                      <span class="badge badge-active" style="font-size:0.72rem">Paid</span>
                      <div style="font-size:0.72rem;color:var(--gray-500);margin-top:3px;text-transform:capitalize"><%= b.Method || '' %></div>
                    <% } else if (b.BookingStatus === 'cancelled') { %>
                      <span style="color:var(--gray-300);font-size:0.8rem">—</span>
                    <% } else { %>
                      <span class="badge badge-pending" style="font-size:0.72rem">Unpaid</span>
                    <% } %>
                  </td>

                  <td>
                    <span class="badge badge-<%= b.BookingStatus %>"><%= b.BookingStatus %></span>
                    <div style="font-size:0.72rem;color:var(--gray-400);margin-top:3px">
                      <%= new Date(b.BookingTime).toLocaleDateString('en-PK', {dateStyle:'medium'}) %>
                    </div>
                  </td>

                  <td>
                    <% if (b.BookingStatus === 'completed' && Number(b.HasReviewed) === 0) { %>
                      <a href="/passenger/reviews" class="btn btn-warning btn-sm" style="white-space:nowrap">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        Write Review
                      </a>
                    <% } else if (b.BookingStatus === 'completed' && Number(b.HasReviewed) > 0) { %>
                      <span style="font-size:0.78rem;color:var(--green);font-weight:600">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline;vertical-align:middle"><polyline points="20 6 9 17 4 12"/></svg>
                        Reviewed
                      </span>
                    <% } else { %>
                      <span style="color:var(--gray-300);font-size:0.8rem">—</span>
                    <% } %>
                  </td>

                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="empty-filtered" id="emptyFiltered">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--gray-200);margin-bottom:8px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <div>No trips match this filter.</div>
        </div>
      </div>

    <% } %>
  </div>

  <script>
    function filterStatus(status, btn) {
      document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var rows    = document.querySelectorAll('#bookingsBody tr[data-status]');
      var visible = 0;
      rows.forEach(function(row) {
        var show = status === 'all' || row.dataset.status === status;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.getElementById('emptyFiltered').style.display = visible === 0 ? 'block' : 'none';
    }
  </script>

</body>
</html>
