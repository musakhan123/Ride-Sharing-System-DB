<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Driver Counter Offer - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .response-layout { max-width: 620px; margin: 0 auto; }

    .offer-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      margin-bottom: 20px;
    }
    .offer-card-header {
      padding: 16px 22px;
      border-bottom: 1px solid var(--gray-100);
      background: var(--gray-50);
      display: flex; align-items: center; gap: 10px;
    }
    .offer-card-header h2 { margin: 0; font-size: 1rem; font-weight: 700; color: var(--gray-800); }
    .offer-card-body { padding: 22px; }

    .fare-compare {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 12px;
      align-items: center;
      margin-bottom: 22px;
    }
    .fare-box {
      padding: 16px;
      border-radius: var(--radius);
      text-align: center;
    }
    .fare-box.yours { background: #fef9c3; border: 1px solid #fde68a; }
    .fare-box.driver { background: #d1fae5; border: 1px solid #6ee7b7; }
    .fare-box-label { font-size: 0.75rem; font-weight: 600; color: var(--gray-500); margin-bottom: 4px; }
    .fare-box-amount { font-size: 1.3rem; font-weight: 800; color: var(--gray-900); }
    .fare-box.yours  .fare-box-amount { color: #92400e; }
    .fare-box.driver .fare-box-amount { color: #065f46; }
    .fare-arrow { color: var(--gray-300); text-align: center; }

    .detail-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 9px 0; border-bottom: 1px solid var(--gray-100); font-size: 0.875rem;
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { color: var(--gray-500); }
    .detail-value { color: var(--gray-900); font-weight: 600; }

    .route-block {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 16px;
      background: var(--blue-50);
      border-radius: var(--radius);
      border: 1px solid var(--blue-100, #dbeafe);
      margin-bottom: 18px;
    }
    .route-loc { flex: 1; text-align: center; }
    .route-loc strong { display: block; font-size: 0.95rem; color: var(--blue-700, #1d4ed8); }
    .route-loc span   { font-size: 0.72rem; color: var(--blue-500, #3b82f6); }

    .respond-actions { display: flex; gap: 12px; }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">
    <div class="response-layout">

      <div class="page-header">
        <h1>Driver Counter Offer</h1>
        <p>The driver has responded to your fare proposal with a different amount.</p>
      </div>

      <% if (booking.FareStatus !== 'countered') { %>
        <div class="alert alert-warning">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          This booking is not in a counter-offer state.
          <a href="/passenger/my-bookings" style="color:inherit;font-weight:600;margin-left:6px">View my bookings →</a>
        </div>
      <% } else { %>

        <!-- ── Fare comparison ─────────────────────────────────── -->
        <div class="offer-card">
          <div class="offer-card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue-600)" stroke-width="2">
              <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/>
              <polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
            </svg>
            <h2>Fare Negotiation — Booking #<%= booking.BookingID %></h2>
          </div>
          <div class="offer-card-body">
            <div class="fare-compare">
              <div class="fare-box yours">
                <div class="fare-box-label">Your Proposal</div>
                <div class="fare-box-amount">Rs. <%= Number(booking.ProposedFare).toLocaleString('en-PK') %></div>
              </div>
              <div class="fare-arrow">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 14 19 10 15 6"/><line x1="19" y1="10" x2="5" y2="10"/>
                </svg>
              </div>
              <div class="fare-box driver">
                <div class="fare-box-label">Driver's Counter</div>
                <div class="fare-box-amount">Rs. <%= Number(booking.DriverFare).toLocaleString('en-PK') %></div>
              </div>
            </div>

            <div class="route-block">
              <div class="route-loc">
                <strong><%= booking.Origin %></strong>
                <span><%= booking.OriginCity %></span>
              </div>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue-400,#60a5fa)" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              <div class="route-loc">
                <strong><%= booking.Destination %></strong>
                <span><%= booking.DestinationCity %></span>
              </div>
            </div>

            <div class="detail-row">
              <span class="detail-label">Departure</span>
              <span class="detail-value"><%= new Date(booking.DepartureTime).toLocaleString('en-PK', {dateStyle:'medium', timeStyle:'short'}) %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Driver</span>
              <span class="detail-value"><%= booking.DriverName %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Vehicle</span>
              <span class="detail-value"><%= booking.Make %> <%= booking.Model %> · <code style="background:var(--gray-100);padding:1px 6px;border-radius:4px;font-size:0.78rem"><%= booking.PlateNumber %></code></span>
            </div>
          </div>
        </div>

        <!-- ── Accept / Reject buttons ────────────────────────── -->
        <div style="background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);padding:22px;box-shadow:var(--shadow-sm)">
          <p style="margin:0 0 16px;font-size:0.875rem;color:var(--gray-700)">
            Do you accept the driver's counter offer of <strong>Rs. <%= Number(booking.DriverFare).toLocaleString('en-PK') %></strong>?
            Accepting will confirm your booking and take you to payment.
          </p>
          <div class="respond-actions">
            <form action="/passenger/fare-accept/<%= booking.BookingID %>" method="POST" style="margin:0;flex:1">
              <input type="hidden" name="action" value="accept">
              <button type="submit" class="btn btn-success" style="width:100%;justify-content:center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Accept — Rs. <%= Number(booking.DriverFare).toLocaleString('en-PK') %>
              </button>
            </form>
            <form action="/passenger/fare-accept/<%= booking.BookingID %>" method="POST" style="margin:0;flex:1"
                  onsubmit="return confirm('Reject this counter offer? The booking will be cancelled.')">
              <input type="hidden" name="action" value="reject">
              <button type="submit" class="btn btn-danger" style="width:100%;justify-content:center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Reject Offer
              </button>
            </form>
          </div>
          <div style="text-align:center;margin-top:14px">
            <a href="/passenger/my-bookings" style="font-size:0.8rem;color:var(--gray-400);text-decoration:none">← Back to My Bookings</a>
          </div>
        </div>

      <% } %>
    </div>
  </div>

</body>
</html>
