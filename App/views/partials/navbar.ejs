<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <img src="/images/logo.svg" alt="Ride Sharing System" height="32">
    </a>
    <div class="nav-links">
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (user.Role === 'admin') { %>
          <a href="/admin/dashboard" class="nav-link">Admin Panel</a>
          <a href="/admin/stats" class="nav-link">Stats</a>
        <% } else if (user.Role === 'driver') { %>
          <a href="/driver/dashboard" class="nav-link">Dashboard</a>
          <a href="/driver/fare-requests" class="nav-link">Fare Requests</a>
          <a href="/driver/ride-history" class="nav-link">History</a>
        <% } else { %>
          <a href="/passenger/dashboard" class="nav-link">Dashboard</a>
          <a href="/passenger/my-bookings" class="nav-link">My Bookings</a>
          <a href="/passenger/ride-history" class="nav-link">History</a>
          <a href="/passenger/reviews" class="nav-link">Reviews</a>
        <% } %>
        <% if (user.Role !== 'admin') { %>
          <a href="/profile" class="nav-link">Profile</a>
        <% } %>
        <span class="nav-user">
          <span class="nav-user-dot"></span>
          <%= user.Name %>
        </span>
        <form action="/auth/logout" method="POST" style="margin:0">
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="nav-link">Login</a>
        <a href="/auth/register" class="btn btn-sm">Register</a>
      <% } %>
    </div>
  </div>
</nav>

<!-- ── Toast container ──────────────────────────────────────────────── -->
<div id="toast-container" aria-live="polite"></div>

<style>
  #toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }
  .toast {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    min-width: 280px;
    max-width: 360px;
    padding: 14px 16px;
    border-radius: 10px;
    border-left: 4px solid;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    font-size: 0.875rem;
    line-height: 1.45;
    pointer-events: all;
    cursor: default;
    animation: toastIn 0.25s ease;
  }
  .toast.toast-link { cursor: pointer; }
  .toast.toast-info     { background:#eff6ff; border-color:#3b82f6; color:#1e40af; }
  .toast.toast-success  { background:#d1fae5; border-color:#059669; color:#065f46; }
  .toast.toast-error    { background:#fee2e2; border-color:#ef4444; color:#991b1b; }
  .toast.toast-warning  { background:#fff7ed; border-color:#f97316; color:#9a3412; }
  .toast-icon { flex-shrink:0; margin-top:1px; }
  .toast-body { flex:1; min-width:0; }
  .toast-title { font-weight:700; margin-bottom:2px; }
  .toast-msg   { opacity:0.85; }
  .toast-hint  { font-size:0.75rem; margin-top:4px; opacity:0.7; }
  .toast-close {
    flex-shrink:0; background:none; border:none; cursor:pointer;
    opacity:0.5; font-size:1rem; line-height:1; padding:0; color:inherit;
    margin-top:-1px;
  }
  .toast-close:hover { opacity:1; }
  .toast-out { animation: toastOut 0.3s ease forwards; }
  @keyframes toastIn  { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:translateX(0); } }
  @keyframes toastOut { from { opacity:1; transform:translateX(0);    } to { opacity:0; transform:translateX(40px); } }
</style>

<% if (typeof user !== 'undefined' && user && user.Role !== 'admin') { %>
<script src="/socket.io/socket.io.js"></script>
<script>
(function () {
  var socket = window._rideSocket = io();
  var userRole = '<%= user.Role %>';
  socket.emit('register', '<%= user.UserID %>');

  // ── Toast helper ────────────────────────────────────────────────────
  window.showToast = showToast;
  function showToast(type, title, msg, href) {
    var icons = {
      info:    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
      success: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>',
      error:   '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
      warning: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>'
    };

    var toast = document.createElement('div');
    toast.className = 'toast toast-' + type + (href ? ' toast-link' : '');
    toast.innerHTML =
      '<span class="toast-icon">' + (icons[type] || icons.info) + '</span>' +
      '<div class="toast-body">' +
        '<div class="toast-title">' + title + '</div>' +
        (msg ? '<div class="toast-msg">' + msg + '</div>' : '') +
        (href ? '<div class="toast-hint">Click to open →</div>' : '') +
      '</div>' +
      '<button class="toast-close" title="Dismiss">✕</button>';

    if (href) {
      toast.addEventListener('click', function (e) {
        if (!e.target.classList.contains('toast-close')) {
          window.location.href = href;
        }
      });
    }

    toast.querySelector('.toast-close').addEventListener('click', function (e) {
      e.stopPropagation();
      dismiss(toast);
    });

    document.getElementById('toast-container').appendChild(toast);

    var timer = setTimeout(function () { dismiss(toast); }, 5000);
    toast._timer = timer;
  }

  function dismiss(toast) {
    clearTimeout(toast._timer);
    toast.classList.add('toast-out');
    setTimeout(function () { toast.remove(); }, 300);
  }

  // ── Role-guarded socket listeners ───────────────────────────────────────

  socket.on('new-fare-request', function (data) {
    if (userRole !== 'driver') return;
    var fare   = Number(data.proposedFare).toLocaleString('en-PK');
    var detail = (data.passengerName || 'A passenger') + ' &middot; <strong>Rs. ' + fare + '</strong>';
    if (data.origin && data.destination) {
      detail += '<br><span style="font-size:0.8rem;opacity:0.75">' + data.origin + ' &rarr; ' + data.destination;
      if (data.departureTime) {
        detail += ' &middot; ' + new Date(data.departureTime).toLocaleString('en-PK', { dateStyle: 'short', timeStyle: 'short' });
      }
      detail += '</span>';
    }
    showToast('info', 'New Fare Request', detail, '/driver/fare-requests');
  });

  socket.on('fare-accepted', function (data) {
    if (userRole !== 'driver') return;
    var fare = Number(data.driverFare).toLocaleString('en-PK');
    showToast(
      'success',
      'Fare Accepted!',
      (data.passengerName || 'Passenger') + ' accepted your counter of Rs. ' + fare,
      '/driver/fare-requests'
    );
  });

  socket.on('fare-approved', function (data) {
    if (userRole !== 'passenger') return;
    var fare = Number(data.proposedFare).toLocaleString('en-PK');
    showToast(
      'success',
      'Fare Approved!',
      'Rs. ' + fare + ' accepted. Redirecting to payment…'
    );
    setTimeout(function () {
      window.location.href = '/passenger/payment/' + data.bookingId;
    }, 3000);
  });

  socket.on('fare-rejected', function () {
    if (userRole === 'driver') {
      showToast('error', 'Counter Offer Rejected', 'Passenger declined your counter offer.');
    } else if (userRole === 'passenger') {
      showToast('error', 'Fare Rejected', 'The driver rejected your fare proposal.');
    }
  });

  socket.on('fare-counter', function (data) {
    if (userRole !== 'passenger') return;
    var fare   = Number(data.driverFare).toLocaleString('en-PK');
    var detail = (data.driverName || 'Driver') + ' countered with <strong>Rs. ' + fare + '</strong>';
    if (data.origin && data.destination) {
      detail += '<br><span style="font-size:0.8rem;opacity:0.75">' + data.origin + ' &rarr; ' + data.destination;
      if (data.departureTime) {
        detail += ' &middot; ' + new Date(data.departureTime).toLocaleString('en-PK', { dateStyle: 'short', timeStyle: 'short' });
      }
      detail += '</span>';
    }
    showToast('warning', 'Counter Offer Received', detail, '/passenger/fare-response/' + data.bookingId);
  });

  socket.on('verification-status-changed', function (data) {
    if (userRole !== 'driver') return;
    if (window.showToast) {
      var msgs = {
        verified:  ['success', 'Identity Verified!',    'Your documents have been approved.'],
        pending:   ['info',    'Verification Pending',   'Your documents are under review.'],
        rejected:  ['error',   'Verification Rejected',  'Your documents were rejected. Please resubmit.'],
        suspended: ['error',   'Account Suspended',      'Your identity verification has been suspended. Contact support.']
      };
      var m = msgs[data.status] || ['info', 'Status Updated', 'Your verification status has changed.'];
      showToast(m[0], m[1], m[2]);
    }
  });

})();
</script>
<% } %>
