<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register Vehicle - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper" style="max-width:560px">

    <div class="page-header">
      <h1>Vehicle Registration</h1>
      <p>Record your vehicle's official government registration certificate.</p>
    </div>

    <% if (success) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <%= success %>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
    <% } %>

    <% if (vehicles.length === 0) { %>
      <div class="card">
        <div class="card-body">
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <p>No vehicles on file. <a href="/driver/dashboard" style="color:var(--blue-600)">Add a vehicle</a> on the dashboard first.</p>
          </div>
        </div>
      </div>

    <% } else { %>
      <div class="card">
        <div class="card-header">
          <h2>Registration Details</h2>
          <div class="card-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
        </div>
        <div class="card-body">
          <form action="/driver/register-vehicle" method="POST">
            <div style="display:flex;flex-direction:column;gap:16px">

              <div class="form-group">
                <label for="vehicleId">Vehicle</label>
                <select id="vehicleId" name="vehicleId" required>
                  <option value="">Select a vehicle</option>
                  <% vehicles.forEach(v => { %>
                    <% const isReg = registeredIds.includes(v.VehicleID); %>
                    <option value="<%= v.VehicleID %>" <%= isReg ? 'disabled' : '' %>>
                      <%= v.Make %> <%= v.Model %> — <%= v.PlateNumber %><%= isReg ? ' (already registered)' : '' %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <div class="form-group">
                <label for="registrationNumber">Registration Number</label>
                <input type="text" id="registrationNumber" name="registrationNumber"
                       placeholder="e.g. PB-2024-12345" required>
              </div>

              <div class="form-group">
                <label for="expiryDate">Expiry Date</label>
                <input type="date" id="expiryDate" name="expiryDate" required>
              </div>

              <button type="submit" class="btn btn-primary">Submit Registration</button>
            </div>
          </form>
        </div>
      </div>

      <% const alreadyRegistered = vehicles.filter(v => registeredIds.includes(v.VehicleID)); %>
      <% if (alreadyRegistered.length > 0) { %>
        <div class="card" style="margin-top:20px">
          <div class="card-header">
            <h2>Already Registered</h2>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Vehicle</th>
                  <th>Plate</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% alreadyRegistered.forEach(v => { %>
                  <tr>
                    <td><strong><%= v.Make %></strong> <%= v.Model %></td>
                    <td><code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:0.8rem"><%= v.PlateNumber %></code></td>
                    <td><span class="badge badge-active">Registered</span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    <% } %>

  </div>

</body>
</html>
