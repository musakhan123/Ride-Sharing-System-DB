<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register Vehicle - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper" style="max-width:560px">

    <div class="page-header">
      <div style="display:flex;align-items:center;gap:12px">
        <a href="/driver/dashboard" style="display:flex;align-items:center;color:var(--gray-400);text-decoration:none" title="Back to dashboard">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </a>
        <h1>Vehicle Registration</h1>
      </div>
      <p>Submit your vehicle's official government registration certificate.</p>
    </div>

    <% if (success) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <%= success %>
      </div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
    <% } %>

    <!-- Vehicle summary card -->
    <% if (vehicle) { %>
      <div class="card" style="margin-bottom:20px">
        <div class="card-body" style="padding:16px 20px">
          <div style="display:flex;align-items:center;gap:14px">
            <div style="width:44px;height:44px;flex-shrink:0;border-radius:50%;background:var(--blue-50);display:flex;align-items:center;justify-content:center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue-600)" stroke-width="1.8">
                <rect x="1" y="3" width="15" height="13" rx="2"/>
                <path d="M16 8h4l3 5v3h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <div style="flex:1">
              <div style="font-weight:700;font-size:1rem;color:var(--gray-900)">
                <%= vehicle.Make %> <%= vehicle.Model %>
              </div>
              <div style="font-size:0.82rem;color:var(--gray-600);margin-top:2px">
                <%= vehicle.Color %> &nbsp;·&nbsp;
                <code style="background:var(--gray-100);padding:1px 6px;border-radius:4px"><%= vehicle.PlateNumber %></code>
                &nbsp;·&nbsp; <%= vehicle.SeatingCapacity %> seats
              </div>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <% if (existingReg && existingReg.Status === 'pending') { %>

      <!-- Pending state -->
      <div class="alert" style="background:#fef3c7;color:#78350f;border:1px solid #fcd34d;border-radius:var(--radius);padding:14px 18px;display:flex;align-items:center;gap:10px;margin-bottom:20px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <div>
          <div style="font-weight:600">Registration pending admin review.</div>
          <div style="font-size:0.85rem;margin-top:2px">
            Submitted <%= new Date(existingReg.ExpiryDate ? existingReg.ExpiryDate : Date.now()).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %> — reg. no. <strong><%= existingReg.RegistrationNumber %></strong>
          </div>
        </div>
      </div>

    <% } else if (existingReg && existingReg.Status === 'active') { %>

      <!-- Active state -->
      <div class="alert" style="background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;border-radius:var(--radius);padding:14px 18px;display:flex;align-items:center;gap:10px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <div>
          <div style="font-weight:600">Registration active.</div>
          <div style="font-size:0.85rem;margin-top:2px">
            Reg. no. <strong><%= existingReg.RegistrationNumber %></strong>
            &nbsp;·&nbsp; Expires <%= new Date(existingReg.ExpiryDate).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %>
          </div>
        </div>
      </div>

    <% } else { %>

      <!-- Suspended banner (resubmission allowed) -->
      <% if (existingReg && existingReg.Status === 'suspended') { %>
        <div class="alert alert-error" style="margin-bottom:24px">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
          <div>
            <div style="font-weight:600">Registration was rejected. Please resubmit with the correct documents.</div>
          </div>
        </div>
      <% } %>

      <!-- Registration form -->
      <div class="card">
        <div class="card-header">
          <h2><%= existingReg ? 'Resubmit Registration' : 'Registration Details' %></h2>
          <div class="card-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
        </div>
        <div class="card-body">
          <form action="/driver/register-vehicle/<%= vehicle.VehicleID %>" method="POST" enctype="multipart/form-data">
            <div style="display:flex;flex-direction:column;gap:18px">

              <div class="form-group">
                <label for="registrationNumber">Registration Number</label>
                <input type="text" id="registrationNumber" name="registrationNumber"
                       placeholder="e.g. PB-2024-12345"
                       value="<%= existingReg ? existingReg.RegistrationNumber : '' %>" required>
              </div>

              <div class="form-group">
                <label for="expiryDate">Expiry Date</label>
                <input type="date" id="expiryDate" name="expiryDate"
                       value="<%= existingReg && existingReg.ExpiryDate ? new Date(existingReg.ExpiryDate).toISOString().split('T')[0] : '' %>"
                       required>
              </div>

              <div class="form-group">
                <label>
                  Registration Document
                  <span style="font-weight:400;color:var(--gray-500)"> — JPG, PNG, or PDF, max 5 MB (optional)</span>
                </label>
                <label class="file-upload-zone" id="fileZone" for="registrationDoc">
                  <div class="fuz-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <polyline points="16 16 12 12 8 16"/>
                      <line x1="12" y1="12" x2="12" y2="21"/>
                      <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
                    </svg>
                  </div>
                  <div class="fuz-label" id="fuz-label">
                    <strong>Click to upload</strong>&nbsp;or drag a file here
                  </div>
                  <div class="fuz-hint" id="fuz-hint">JPG, PNG or PDF up to 5 MB</div>
                  <input type="file" id="registrationDoc" name="registrationDoc"
                         accept=".jpg,.jpeg,.png,.pdf">
                </label>
              </div>

              <div style="display:flex;gap:10px;margin-top:2px">
                <button type="submit" class="btn btn-primary">
                  <%= existingReg ? 'Resubmit Registration' : 'Submit Registration' %>
                </button>
                <a href="/driver/dashboard" class="btn btn-secondary">Cancel</a>
              </div>

            </div>
          </form>
        </div>
      </div>

    <% } %>

  </div>

  <script>
    (function () {
      var input = document.getElementById('registrationDoc');
      if (!input) return;
      var zone  = document.getElementById('fileZone');
      var label = document.getElementById('fuz-label');
      var hint  = document.getElementById('fuz-hint');
      input.addEventListener('change', function () {
        if (!this.files.length) return;
        var f = this.files[0];
        label.innerHTML = '<strong>' + f.name + '</strong>';
        hint.textContent = (f.size / 1024 / 1024).toFixed(2) + ' MB — click to change';
        zone.classList.add('has-file');
      });
    })();
  </script>

</body>
</html>
