<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Driver Dashboard - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    @keyframes fare-pulse {
      0%   { box-shadow: 0 0 0 0   rgba(59,130,246,0.55); }
      60%  { box-shadow: 0 0 0 10px rgba(59,130,246,0);   }
      100% { box-shadow: 0 0 0 0   rgba(59,130,246,0);    }
    }
    .fare-pulse { animation: fare-pulse 0.75s ease-out 3; }

    /* ── Setup progress badge ───────────────────────────────────────── */
    .setup-badge {
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      padding: 14px 20px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    .setup-badge:hover { box-shadow: var(--shadow-md); border-color: var(--blue-200); }
    .setup-ring { position: relative; width: 48px; height: 48px; flex-shrink: 0; }
    .setup-ring-pct {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.68rem; font-weight: 800; color: var(--blue-700);
    }
    .setup-badge-text { flex: 1; min-width: 0; }
    .setup-badge-title { font-size: 0.875rem; font-weight: 700; color: var(--gray-800); margin-bottom: 2px; }
    .setup-badge-sub   { font-size: 0.78rem; color: var(--gray-500); }
    .setup-badge-bar   { margin-top: 7px; height: 4px; background: var(--gray-100); border-radius: 99px; overflow: hidden; max-width: 180px; }
    .setup-badge-fill  { height: 4px; border-radius: 99px; background: var(--blue-600); }
    .setup-badge-fill.complete { background: #059669; }
    .setup-badge-cta   { font-size: 0.8rem; font-weight: 600; color: var(--blue-600); white-space: nowrap; flex-shrink: 0; }
  </style>
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <div class="page-header">
      <h1>Driver Dashboard</h1>
      <p>Manage your rides and vehicles, <%= user.Name %>.</p>
    </div>

    <!-- ── Flash banners ─────────────────────────────────────────────── -->
    <% if (idSubmitted) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Identity documents submitted. Your verification is now pending admin review.
      </div>
    <% } %>
    <% if (added) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Vehicle added successfully. You can now register it below.
      </div>
    <% } %>
    <% if (registered) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Vehicle registration submitted. Pending admin approval.
      </div>
    <% } %>
    <% if (ridePosted) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Ride posted successfully.
      </div>
    <% } %>
    <% if (typeof rideCompleted !== 'undefined' && rideCompleted) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Ride marked as completed. All confirmed bookings have been updated.
      </div>
    <% } %>
    <% if (vehicleError === 'identity_suspended') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        Your account is suspended. Contact admin.
      </div>
    <% } else if (vehicleError === 'identity_not_verified') { %>
      <div class="alert alert-warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Please verify your identity before adding a vehicle.
      </div>
    <% } %>
    <% if (rideError === 'identity_suspended') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        Your account has been suspended. Contact admin to resolve this before posting rides.
      </div>
    <% } else if (rideError === 'identity_not_verified') { %>
      <div class="alert alert-warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Please verify your identity before posting a ride.
      </div>
    <% } else if (rideError === 'vehicle_suspended') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        This vehicle's registration has been suspended. Contact admin to resolve this.
      </div>
    <% } else if (rideError === 'vehicle_not_active') { %>
      <div class="alert alert-warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        The selected vehicle does not have an active registration. Register and wait for approval before posting rides.
      </div>
    <% } else if (rideError === 'missing_fields') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        All ride fields are required.
      </div>
    <% } %>

    <!-- ── Identity banners ──────────────────────────────────────────── -->
    <div id="identity-status-banner">
    <% if (identityVerification && identityVerification.Status === 'suspended') { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <strong>Account suspended.</strong> Your identity verification has been suspended by an admin. Contact support to resolve this issue.
      </div>
    <% } else if (!identityVerification || identityVerification.Status === 'rejected') { %>
      <div class="alert alert-warning">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span>
          <strong>Identity not verified.</strong>
          <a href="/auth/verify-identity" style="color:inherit;font-weight:600;text-decoration:underline;margin-left:6px">Submit your documents →</a>
        </span>
      </div>
    <% } else if (identityVerification.Status === 'pending') { %>
      <div class="alert alert-info">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Identity verification is <strong>pending review</strong>. We'll notify you once it's processed.
      </div>
    <% } %>
    </div>

    <!-- ── Suspended vehicle banners ─────────────────────────────────── -->
    <% vehicleRegs.forEach(function(vr) { %>
      <% if (vr.Status === 'suspended') { %>
        <div class="alert alert-error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <strong>Vehicle registration suspended.</strong> One of your vehicle registrations has been suspended. Contact admin for details.
        </div>
      <% } %>
    <% }); %>

    <!-- ── Fare requests notification ──────────────────────────────── -->
    <div id="fare-request-banner">
    <% if (pendingFareCount > 0) { %>
      <div class="alert alert-info" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
        <div style="display:flex;align-items:center;gap:10px">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="3"/></svg>
          <span>You have <strong id="fare-banner-count"><%= pendingFareCount %></strong> pending fare request<span id="fare-banner-plural"><%= pendingFareCount !== 1 ? 's' : '' %></span> from passengers.</span>
        </div>
        <a href="/driver/fare-requests" class="btn btn-primary btn-sm" style="flex-shrink:0">Review Requests →</a>
      </div>
    <% } %>
    </div>

    <!-- ── Stats ─────────────────────────────────────────────────────── -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Rides</div>
        <div class="stat-value"><%= rides.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Active Rides</div>
        <div class="stat-value green"><%= rides.filter(r => r.Status === 'active').length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">My Vehicles</div>
        <div class="stat-value"><%= vehicles.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Available Seats</div>
        <div class="stat-value yellow"><%= rides.filter(r => r.Status === 'active').reduce((s, r) => s + r.AvailableSeats, 0) %></div>
      </div>
      <div class="stat-card" id="fare-stat-card" style="cursor:pointer;position:relative" onclick="location.href='/driver/fare-requests'">
        <div class="stat-label">Fare Requests</div>
        <div class="stat-value" id="fare-count-value" style="color:var(--blue-600)"><%= pendingFareCount %></div>
        <div id="fare-count-dot" style="position:absolute;top:12px;right:14px;width:8px;height:8px;background:#ef4444;border-radius:50%;<%= pendingFareCount > 0 ? '' : 'display:none' %>"></div>
      </div>
    </div>

    <!-- ── Setup progress badge ─────────────────────────────────────── -->
    <% if (typeof checklist !== 'undefined' && checklist) { %>
    <%
      var _c    = checklist;
      var _done = (_c.IdentityVerified  == 1 ? 1 : 0)
                + (_c.VehicleRegistered == 1 ? 1 : 0)
                + (_c.ProfileCompleted  == 1 ? 1 : 0);
      var _spct = Math.round(_done / 3 * 100);
      var _circ = Math.round(2 * Math.PI * 20); /* circumference ≈ 125 */
    %>
    <a href="/profile" class="setup-badge">
      <div class="setup-ring">
        <svg width="48" height="48" viewBox="0 0 48 48">
          <circle cx="24" cy="24" r="20" fill="none" stroke="var(--gray-100)" stroke-width="4"/>
          <circle cx="24" cy="24" r="20" fill="none"
                  stroke="<%= _done === 3 ? '#059669' : 'var(--blue-600)' %>"
                  stroke-width="4"
                  stroke-dasharray="<%= _circ %>"
                  stroke-dashoffset="<%= Math.round(_circ * (1 - _spct / 100)) %>"
                  stroke-linecap="round"
                  transform="rotate(-90 24 24)"/>
        </svg>
        <div class="setup-ring-pct"><%= _spct %>%</div>
      </div>
      <div class="setup-badge-text">
        <div class="setup-badge-title">Setup Progress</div>
        <div class="setup-badge-sub">
          <% if (_done === 3) { %>
            All steps complete — you're ready to drive!
          <% } else { %>
            <%= _done %>/3 steps complete &middot; tap to finish setup
          <% } %>
        </div>
        <div class="setup-badge-bar">
          <div class="setup-badge-fill <%= _done === 3 ? 'complete' : '' %>" style="width:<%= _spct %>%"></div>
        </div>
      </div>
      <div class="setup-badge-cta">View Checklist →</div>
    </a>
    <% } %>

    <div class="dashboard-grid">

      <!-- ── Post a Ride ────────────────────────────────────────────── -->
      <div class="card">
        <div class="card-header">
          <h2>Post a New Ride</h2>
          <div class="card-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
        </div>
        <div class="card-body">
          <form action="/driver/rides" method="POST">
            <div style="display:flex;flex-direction:column;gap:14px">
              <div class="form-group">
                <label>Vehicle</label>
                <select name="vehicleId" required>
                  <option value="">Select your vehicle</option>
                  <% vehicles.forEach(v => { %>
                    <option value="<%= v.VehicleID %>"><%= v.Make %> <%= v.Model %> — <%= v.PlateNumber %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-grid">
                <div class="form-group">
                  <label>From</label>
                  <select name="originId" required>
                    <option value="">Origin</option>
                    <% locations.forEach(l => { %>
                      <option value="<%= l.LocationID %>"><%= l.LocationName %>, <%= l.City %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-group">
                  <label>To</label>
                  <select name="destinationId" required>
                    <option value="">Destination</option>
                    <% locations.forEach(l => { %>
                      <option value="<%= l.LocationID %>"><%= l.LocationName %>, <%= l.City %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-group">
                  <label>Departure</label>
                  <input type="datetime-local" name="departureTime" required>
                </div>
                <div class="form-group">
                  <label>Total Seats</label>
                  <input type="number" name="totalSeats" min="1" max="20" placeholder="e.g. 3" required>
                </div>
              </div>
              <% if (identityVerification && identityVerification.Status === 'verified') { %>
                <button type="submit" id="post-ride-btn" class="btn btn-primary">Post Ride</button>
              <% } else { %>
                <% var rideBtnTitle = !identityVerification || identityVerification.Status === 'rejected' ? 'Verify identity first' : identityVerification.Status === 'pending' ? 'Verification pending' : 'Account suspended'; %>
                <button type="button" id="post-ride-btn" class="btn btn-primary" style="background:var(--gray-200);color:var(--gray-500);cursor:not-allowed;border:none" disabled title="<%= rideBtnTitle %>">Post Ride</button>
              <% } %>
            </div>
          </form>
        </div>
      </div>

      <!-- ── My Vehicles ────────────────────────────────────────────── -->
      <div class="card">
        <div class="card-header">
          <h2>My Vehicles</h2>
          <div id="add-vehicle-btn-wrap">
          <% if (identityVerification && identityVerification.Status === 'verified') { %>
            <a href="/driver/add-vehicle" class="btn btn-primary btn-sm">+ Add Vehicle</a>
          <% } else if (identityVerification && identityVerification.Status === 'pending') { %>
            <button class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-500);cursor:not-allowed;border:none" disabled title="Verification pending">+ Add Vehicle</button>
          <% } else if (identityVerification && identityVerification.Status === 'suspended') { %>
            <button class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-500);cursor:not-allowed;border:none" disabled title="Account suspended">+ Add Vehicle</button>
          <% } else { %>
            <button class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-500);cursor:not-allowed;border:none" disabled title="Verify identity first">+ Add Vehicle</button>
          <% } %>
          </div>
        </div>
        <% if (vehicles.length === 0) { %>
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <p>No vehicles yet.
              <% if (identityVerification && identityVerification.Status === 'verified') { %>
                <a href="/driver/add-vehicle" style="color:var(--blue-600);font-weight:600">Add your first vehicle →</a>
              <% } else { %>
                <span style="color:var(--gray-400)">Verify your identity to add a vehicle.</span>
              <% } %>
            </p>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Vehicle</th>
                  <th>Plate</th>
                  <th>Seats</th>
                  <th>Reg. Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% vehicles.forEach(v => { %>
                  <% const reg = vehicleRegs.find(r => r.VehicleID === v.VehicleID); %>
                  <tr>
                    <td>
                      <div style="font-weight:600;color:var(--gray-900)"><%= v.Make %> <%= v.Model %></div>
                      <div style="font-size:0.75rem;color:var(--gray-500)"><%= v.Color %></div>
                    </td>
                    <td><code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:0.8rem"><%= v.PlateNumber %></code></td>
                    <td><%= v.SeatingCapacity %></td>
                    <td>
                      <% if (!reg) { %>
                        <span style="font-size:0.78rem;color:var(--gray-500)">Not registered</span>
                      <% } else if (reg.Status === 'pending') { %>
                        <span class="badge badge-pending">Pending</span>
                      <% } else if (reg.Status === 'active') { %>
                        <span class="badge badge-active">Active</span>
                      <% } else if (reg.Status === 'suspended') { %>
                        <span class="badge badge-suspended">Suspended</span>
                      <% } else if (reg.Status === 'expired') { %>
                        <span class="badge badge-cancelled">Expired</span>
                      <% } else { %>
                        <span class="badge badge-cancelled">Rejected</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (!reg || reg.Status === 'suspended' || reg.Status === 'rejected') { %>
                        <a href="/driver/register-vehicle/<%= v.VehicleID %>"
                           class="btn btn-secondary btn-sm" style="white-space:nowrap">
                          Register
                        </a>
                      <% } else { %>
                        <a href="/driver/register-vehicle/<%= v.VehicleID %>"
                           style="font-size:0.75rem;color:var(--gray-400);text-decoration:none">
                          View
                        </a>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- ── My Recent Rides ─────────────────────────────────────────── -->
      <div class="card full-width">
        <div class="card-header">
          <h2>My Recent Rides</h2>
          <span style="font-size:0.8rem;color:var(--gray-400)">Last 10 rides</span>
        </div>
        <% if (rides.length === 0) { %>
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
            <p>No rides posted yet. Post your first ride above.</p>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>From</th>
                  <th>To</th>
                  <th>Departure</th>
                  <th>Seats</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% rides.forEach(r => { %>
                  <tr>
                    <td><%= r.Origin %></td>
                    <td><%= r.Destination %></td>
                    <td><%= new Date(r.DepartureTime).toLocaleString('en-PK', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
                    <td>
                      <span style="color:var(--blue-600);font-weight:600"><%= r.AvailableSeats %></span>
                      <span style="color:var(--gray-400)">/ <%= r.TotalSeats %></span>
                    </td>
                    <td><span class="badge badge-<%= r.Status %>"><%= r.Status %></span></td>
                    <td>
                      <% if (r.Status === 'active') { %>
                        <form action="/driver/complete-ride/<%= r.RideID %>" method="POST" style="margin:0"
                              onsubmit="return confirm('Mark this ride as completed?')">
                          <button type="submit" class="btn btn-sm" style="font-size:0.75rem;padding:4px 10px">
                            ✓ Complete
                          </button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </div>
  </div>

<script>
(function () {
  if (!window._rideSocket) return;
  var userRole = '<%= user.Role %>';

  // ── New fare request: update badge + banner without page reload ──────────
  window._rideSocket.on('new-fare-request', function (data) {
    if (userRole !== 'driver') return;
    var ICON = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="3"/></svg>';

    // Increment stat counter
    var countEl = document.getElementById('fare-count-value');
    var newCount = (parseInt(countEl ? countEl.textContent : '0') || 0) + 1;
    if (countEl) countEl.textContent = newCount;

    // Show red dot
    var dot = document.getElementById('fare-count-dot');
    if (dot) dot.style.display = '';

    // Update / show the banner
    var banner = document.getElementById('fare-request-banner');
    if (banner) {
      banner.innerHTML =
        '<div class="alert alert-info" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">' +
          '<div style="display:flex;align-items:center;gap:10px">' + ICON +
            '<span>You have <strong>' + newCount + '</strong> pending fare request' + (newCount !== 1 ? 's' : '') + ' from passengers.</span>' +
          '</div>' +
          '<a href="/driver/fare-requests" class="btn btn-primary btn-sm" style="flex-shrink:0">Review Requests →</a>' +
        '</div>';
    }

    // Pulse animation on the stat card
    var card = document.getElementById('fare-stat-card');
    if (card) {
      card.classList.remove('fare-pulse');
      void card.offsetWidth; // force reflow so animation restarts
      card.classList.add('fare-pulse');
    }
  });

  // ── Verification status change ────────────────────────────────────────
  window._rideSocket.on('verification-status-changed', function (data) {
    if (userRole !== 'driver') return;
    updateIdentityUI(data.status);
  });

  function updateIdentityUI(status) {
    var ICON_WARN  = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
    var ICON_ERR   = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
    var ICON_INFO  = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';

    // ── Identity banner ──────────────────────────────────────────────
    var banner = document.getElementById('identity-status-banner');
    if (banner) {
      if (status === 'verified') {
        banner.innerHTML = '';
      } else if (status === 'suspended') {
        banner.innerHTML = '<div class="alert alert-error">' + ICON_ERR + '<strong>Account suspended.</strong> Your identity verification has been suspended by an admin. Contact support to resolve this issue.</div>';
      } else if (status === 'pending') {
        banner.innerHTML = '<div class="alert alert-info">' + ICON_INFO + 'Identity verification is <strong>pending review</strong>. We\'ll notify you once it\'s processed.</div>';
      } else {
        banner.innerHTML = '<div class="alert alert-warning">' + ICON_WARN + '<span><strong>Identity not verified.</strong><a href="/auth/verify-identity" style="color:inherit;font-weight:600;text-decoration:underline;margin-left:6px">Submit your documents →</a></span></div>';
      }
    }

    // ── Post Ride button ─────────────────────────────────────────────
    var rideBtn = document.getElementById('post-ride-btn');
    if (rideBtn) {
      if (status === 'verified') {
        rideBtn.type = 'submit';
        rideBtn.disabled = false;
        rideBtn.removeAttribute('style');
        rideBtn.removeAttribute('title');
      } else {
        var rideTitle = status === 'suspended' ? 'Account suspended' : status === 'pending' ? 'Verification pending' : 'Verify identity first';
        rideBtn.type = 'button';
        rideBtn.disabled = true;
        rideBtn.style.cssText = 'background:var(--gray-200);color:var(--gray-500);cursor:not-allowed;border:none';
        rideBtn.title = rideTitle;
      }
    }

    // ── Add Vehicle button ───────────────────────────────────────────
    var addWrap = document.getElementById('add-vehicle-btn-wrap');
    if (addWrap) {
      if (status === 'verified') {
        addWrap.innerHTML = '<a href="/driver/add-vehicle" class="btn btn-primary btn-sm">+ Add Vehicle</a>';
      } else {
        var vTitle = status === 'pending' ? 'Verification pending' : status === 'suspended' ? 'Account suspended' : 'Verify identity first';
        addWrap.innerHTML = '<button class="btn btn-sm" style="background:var(--gray-200);color:var(--gray-500);cursor:not-allowed;border:none" disabled title="' + vTitle + '">+ Add Vehicle</button>';
      }
    }
  }
})();
</script>

</body>
</html>
