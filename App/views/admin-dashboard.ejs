<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - Ride Sharing System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
      <div>
        <div style="display:flex;align-items:center;gap:10px">
          <h1>Admin Panel</h1>
          <span class="badge badge-driver" style="font-size:0.7rem;letter-spacing:0.5px">ADMIN</span>
        </div>
        <p>Review and action pending identity verifications and vehicle registrations.</p>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Pending ID Verifications</div>
        <div class="stat-value yellow"><%= identityVerifications.filter(iv => iv.Status === 'pending').length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Pending Vehicle Regs</div>
        <div class="stat-value yellow"><%= vehicleRegistrations.filter(vr => vr.Status === 'pending').length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Verifications</div>
        <div class="stat-value"><%= identityVerifications.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-value"><%= totalUsers %></div>
      </div>
    </div>

    <!-- Identity Verifications -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header">
        <h2>Identity Verifications</h2>
        <span style="font-size:0.8rem;color:var(--gray-400)"><%= identityVerifications.length %> total</span>
      </div>

      <% if (identityVerifications.length === 0) { %>
        <div class="empty-state">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p>No verification requests yet.</p>
        </div>
      <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Doc Type</th>
                <th>Doc Number</th>
                <th>File</th>
                <th>Submitted</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% identityVerifications.forEach(iv => { %>
                <tr>
                  <td>
                    <div style="font-weight:600;color:var(--gray-900);font-size:0.875rem"><%= iv.UserName %></div>
                    <div style="font-size:0.78rem;color:var(--gray-500, var(--gray-600))"><%= iv.Email %></div>
                  </td>
                  <td style="text-transform:capitalize"><%= iv.DocumentType.replace('_', ' ') %></td>
                  <td><code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:0.78rem"><%= iv.DocumentNumber %></code></td>
                  <td>
                    <% if (iv.DocumentFile) { %>
                      <a href="/uploads/<%= iv.DocumentFile %>" target="_blank"
                         style="color:var(--blue-600);font-size:0.8rem;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;gap:4px">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        View
                      </a>
                    <% } else { %>
                      <span style="color:var(--gray-400);font-size:0.8rem">—</span>
                    <% } %>
                  </td>
                  <td style="font-size:0.8rem;color:var(--gray-600)">
                    <%= new Date(iv.SubmittedAt).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %>
                  </td>
                  <td>
                    <% if (iv.Status === 'verified') { %>
                      <span class="badge badge-active">Verified</span>
                    <% } else if (iv.Status === 'pending') { %>
                      <span class="badge badge-pending">Pending</span>
                    <% } else { %>
                      <span class="badge badge-cancelled">Rejected</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (iv.Status === 'pending') { %>
                      <div style="display:flex;gap:6px">
                        <form action="/admin/verify/<%= iv.VerificationID %>" method="POST" style="margin:0">
                          <input type="hidden" name="action" value="approve">
                          <button type="submit" class="btn btn-success btn-sm">Approve</button>
                        </form>
                        <form action="/admin/verify/<%= iv.VerificationID %>" method="POST" style="margin:0">
                          <input type="hidden" name="action" value="reject">
                          <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                      </div>
                    <% } else { %>
                      <span style="color:var(--gray-400);font-size:0.8rem">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Vehicle Registrations -->
    <div class="card">
      <div class="card-header">
        <h2>Vehicle Registrations</h2>
        <span style="font-size:0.8rem;color:var(--gray-400)"><%= vehicleRegistrations.length %> total</span>
      </div>

      <% if (vehicleRegistrations.length === 0) { %>
        <div class="empty-state">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <p>No vehicle registrations yet.</p>
        </div>
      <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Driver</th>
                <th>Vehicle</th>
                <th>Plate</th>
                <th>Reg. Number</th>
                <th>Expiry</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% vehicleRegistrations.forEach(vr => { %>
                <tr>
                  <td>
                    <div style="font-weight:600;color:var(--gray-900);font-size:0.875rem"><%= vr.DriverName %></div>
                    <div style="font-size:0.78rem;color:var(--gray-500, var(--gray-600))"><%= vr.DriverEmail %></div>
                  </td>
                  <td>
                    <strong><%= vr.Make %></strong> <%= vr.Model %>
                    <div style="font-size:0.78rem;color:var(--gray-600)"><%= vr.Color %></div>
                  </td>
                  <td><code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:0.78rem"><%= vr.PlateNumber %></code></td>
                  <td><code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:0.78rem"><%= vr.RegistrationNumber %></code></td>
                  <td style="font-size:0.8rem;color:var(--gray-600)">
                    <%= new Date(vr.ExpiryDate).toLocaleDateString('en-PK', { dateStyle: 'medium' }) %>
                  </td>
                  <td>
                    <% if (vr.Status === 'active') { %>
                      <span class="badge badge-active">Active</span>
                    <% } else if (vr.Status === 'pending') { %>
                      <span class="badge badge-pending">Pending</span>
                    <% } else if (vr.Status === 'expired') { %>
                      <span class="badge badge-cancelled">Expired</span>
                    <% } else { %>
                      <span class="badge badge-pending">Suspended</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (vr.Status === 'pending') { %>
                      <div style="display:flex;gap:6px">
                        <form action="/admin/vehicle/<%= vr.RegistrationID %>" method="POST" style="margin:0">
                          <input type="hidden" name="action" value="approve">
                          <button type="submit" class="btn btn-success btn-sm">Approve</button>
                        </form>
                        <form action="/admin/vehicle/<%= vr.RegistrationID %>" method="POST" style="margin:0">
                          <input type="hidden" name="action" value="reject">
                          <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                      </div>
                    <% } else { %>
                      <span style="color:var(--gray-400);font-size:0.8rem">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>

</body>
</html>
